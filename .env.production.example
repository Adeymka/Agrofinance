APP_NAME=AgroFinance+
APP_ENV=production
APP_KEY=                        # Generer avec: php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=Africa/Porto-Novo
APP_URL=https://votre-domaine.bj

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr              # stdout/stderr pour aggregateur (Loki, Papertrail)
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                 # #40 — error en production (pas debug)

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agrofinanceplus
DB_USERNAME=
DB_PASSWORD=

# #41 — Session et cache Redis en production (scalabilite horizontale)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true      # HTTPS obligatoire
SESSION_PATH=/
SESSION_DOMAIN=.votre-domaine.bj

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis          # Redis pour les queues en prod (Supervisor)

# #41 — Cache Redis
CACHE_STORE=redis
CACHE_PREFIX=agrofinance_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.votre-provider.bj
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@votre-domaine.bj"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=

VITE_APP_NAME="${APP_NAME}"

# FedaPay PRODUCTION
FEDAPAY_SECRET_KEY=sk_live_XXXX
FEDAPAY_PUBLIC_KEY=pk_live_XXXX
FEDAPAY_ENVIRONMENT=live
FEDAPAY_MOCK=false              # JAMAIS true en production
FEDAPAY_HTTP_TIMEOUT=15
FEDAPAY_HTTP_CONNECT_TIMEOUT=5

# Vonage (SMS OTP)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_SMS_FROM=AgroFinance
VONAGE_HTTP_TIMEOUT=15
VONAGE_HTTP_CONNECT_TIMEOUT=5

# Securite metriques (GET /metrics) — generer avec: openssl rand -hex 32
METRICS_TOKEN=

# Ne JAMAIS activer en production
OTP_DEBUG_LOG=false

# Sentry APM (#10) — https://sentry.io
# php artisan sentry:publish --dsn=<DSN>
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_LARAVEL_DSN="${SENTRY_DSN}"
SENTRY_TRACES_SAMPLE_RATE=0.1     # 10% des transactions en prod
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=                   # Ex: git rev-parse --short HEAD dans le CI

# S3 / Object Storage pour les PDFs (#12)
# Decommenter pour migrer les rapports PDF du disque local vers S3
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=AKIAIO...
# AWS_SECRET_ACCESS_KEY=xxxx
# AWS_DEFAULT_REGION=eu-west-1
# AWS_BUCKET=agrofinance-rapports

# Sauvegarde BDD/fichiers (spatie/laravel-backup) (#9)
BACKUP_MAIL_TO=admin@votre-domaine.bj
BACKUP_ARCHIVE_PASSWORD=         # Optionnel : chiffrer les archives de backup
