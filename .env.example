APP_NAME=AgroFinance+
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Porto-Novo
APP_URL=http://localhost/agrofinanceplus/public

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agrofinanceplus
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@agrofinanceplus.bj"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# FedaPay — obtenir les cles sur https://fedapay.com / dashboard (sandbox)
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_ENVIRONMENT=sandbox
# true = pas d'appel API (Postman / dev sans cles). Ne jamais mettre true en prod.
FEDAPAY_MOCK=false
# Timeouts HTTP SDK FedaPay (secondes)
FEDAPAY_HTTP_TIMEOUT=15
FEDAPAY_HTTP_CONNECT_TIMEOUT=5

# Vonage (SMS OTP)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_SMS_FROM=
VONAGE_HTTP_TIMEOUT=15
VONAGE_HTTP_CONNECT_TIMEOUT=5

# Optionnel : Bearer ou ?token= requis pour GET /metrics (recommande en prod)
METRICS_TOKEN=

# Si defini a true (uniquement en local), journalise le code OTP pour le debug.
# Ne pas activer en production.
OTP_DEBUG_LOG=false
