APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# En local XAMPP (sous-dossier), exemple : http://localhost/agrofinanceplus/public
# En production : URL HTTPS canonique (manifest PWA + service worker dérivés automatiquement).
APP_URL=http://localhost
# ASSET_URL=   # optionnel ; CDN ou URL statiques ; laisser vide si tout passe par APP_URL

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# En production : error ou warning pour limiter le bruit (voir docs/SPRINT-S2-ARCHITECTURE-INFRA.md)
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# MySQL / MariaDB (ex. XAMPP ou production) — décommenter et renseigner :
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=agrofinanceplus
# DB_USERNAME=...
# DB_PASSWORD=...
# En cas d’erreur de collation, aligner charset dans config/database.php (voir AGENTS.md).

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# FedaPay — obtenir les clés sur https://fedapay.com / dashboard (sandbox)
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_ENVIRONMENT=sandbox
# true = pas d’appel API (Postman / dev sans clés). Ne jamais mettre true en prod.
FEDAPAY_MOCK=false
#
# URL de callback à déclarer dans le tableau de bord FedaPay (selon le flux utilisé) :
#   - Paiement initié depuis l’API (mobile, Postman) : {APP_URL}/api/v1/abonnement/callback
#   - Paiement initié depuis le navigateur (session web) : {APP_URL}/abonnement/callback
# APP_URL doit être l’URL publique exacte (ex. https://app.example.com), sans slash final inutile.

# Invitation coop (SMS Vonage optionnel)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_SMS_FROM="AgroFinance+"
